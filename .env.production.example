# =====================================================================
# Sporthink — PRODUCTION Environment Variables
# =====================================================================
# Bu dosya Vercel/Railway/etc. dashboard'ına eklenecek değerlerin şablonudur.
# .env.production değil — onu da hassas, git'e koyma!
# =====================================================================

# Database — PostgreSQL ZORUNLU (production'da SQLite KULLANMA)
# Supabase: postgresql://postgres:[PASS]@db.xxxx.supabase.co:5432/postgres
# Neon:     postgresql://[user]:[pass]@xxxx.neon.tech/[db]?sslmode=require
# Railway:  postgresql://postgres:[PASS]@xxxx.railway.app:5432/railway
DATABASE_URL="postgresql://USER:PASS@HOST:5432/DBNAME?schema=public&sslmode=require"

# NextAuth — production URL ve güçlü secret
# Secret oluştur: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE-WITH-STRONG-RANDOM-64CHAR-STRING"
NEXTAUTH_URL="https://sporthink.com"   # Veya https://your-app.vercel.app

# Google Gemini AI API — production için ayrı key öneriyoruz
# Rate limit'i için billing aç: https://aistudio.google.com/apikey
GEMINI_API_KEY="REPLACE-WITH-PRODUCTION-GEMINI-KEY"

# Web Push (VAPID) — yenilemek istemiyorsanız mevcut keyleri kullanabilirsiniz
# Yenisi için: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="REPLACE-WITH-VAPID-PUBLIC-KEY"
VAPID_PRIVATE_KEY="REPLACE-WITH-VAPID-PRIVATE-KEY"
VAPID_SUBJECT="mailto:admin@sporthink.com"

# Node ortamı
NODE_ENV="production"

# OPSIYONEL — Hata izleme (Sentry vb.)
# SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""

# OPSIYONEL — Email gönderimi (SMTP)
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="Sporthink <noreply@sporthink.com>"
