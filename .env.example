# =====================================================================
# Sporthink — Environment Variables Example
# =====================================================================
# Bu dosyayı .env olarak kopyala ve değerleri kendi anahtarlarınla doldur.
# .env dosyası git'e commit EDİLMEZ (.gitignore'da).
# =====================================================================

# Database — SQLite (dev) veya PostgreSQL (prod)
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://USER:PASS@localhost:5432/sporthink?schema=public"

# NextAuth
NEXTAUTH_SECRET="generate-a-secure-random-string-here"
NEXTAUTH_URL="http://localhost:3000"

# Google Gemini AI API (https://aistudio.google.com/apikey)
GEMINI_API_KEY="your-gemini-api-key-here"

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key-here"
VAPID_PRIVATE_KEY="your-vapid-private-key-here"
VAPID_SUBJECT="mailto:admin@yourdomain.com"
