generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Organization ====================

model Region {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores Store[]
  users  User[]
}

model Store {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  address   String?
  isActive  Boolean  @default(true)
  regionId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  region    Region     @relation(fields: [regionId], references: [id])
  users     User[]
  kpiEntries KpiEntry[]
  feedback  Feedback[]
  shifts    Shift[]
  leagueScores LeagueScore[]

  @@index([regionId])
}

// ==================== Identity ====================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      String   // SUPER_ADMIN, REGIONAL_MANAGER, STORE_MANAGER, ASSISTANT_MANAGER, EMPLOYEE
  storeId   String?
  regionId  String?
  isActive  Boolean  @default(true)
  avatarUrl String?
  hireDate  DateTime?
  exitDate  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store     Store?   @relation(fields: [storeId], references: [id])
  region    Region?  @relation(fields: [regionId], references: [id])

  // Training relations
  createdTrainings    Training[]
  trainingAssignments TrainingAssignment[] @relation("AssignedUser")
  assignedByMe        TrainingAssignment[] @relation("AssignedBy")

  // Quiz relations
  quizAttempts QuizAttempt[]

  // KPI relations
  createdKpis  KpiDefinition[]
  kpiEntries   KpiEntry[]     @relation("KpiUser")
  enteredKpis  KpiEntry[]     @relation("KpiEnteredBy")

  // Feedback relations
  submittedFeedback Feedback[]        @relation("SubmittedBy")
  assignedFeedback  Feedback[]        @relation("AssignedTo")
  feedbackComments  FeedbackComment[]
  feedbackLogs      FeedbackLog[]

  // Notes
  receivedNotes ManagerNote[] @relation("NoteEmployee")
  writtenNotes  ManagerNote[] @relation("NoteAuthor")

  // Audit
  auditLogs AuditLog[]

  // Pulse Survey
  surveyResponses PulseSurveyResponse[]
  createdSurveys  PulseSurvey[]

  // Community
  communityPosts    CommunityPost[]
  communityComments CommunityComment[]

  // Sales Simulation
  simAttempts SimAttempt[]

  // Web Push subscriptions
  pushSubscriptions PushSubscription[]

  // App notifications (in-app bildirimler)
  notifications     Notification[]    @relation("NotificationRecipient")

  // Shift & Leave
  shifts            Shift[]           @relation("ShiftEmployee")
  createdShifts     Shift[]           @relation("ShiftCreator")
  leaveRequests     LeaveRequest[]    @relation("LeaveRequester")
  approvedLeaves    LeaveRequest[]    @relation("LeaveApprover")
  leaveBalances     LeaveBalance[]
  shiftSwapsFrom    ShiftSwap[]       @relation("ShiftSwapFrom")
  shiftSwapsTo      ShiftSwap[]       @relation("ShiftSwapTo")

  // Gamification
  xpTransactions    XpTransaction[]
  userBadges        UserBadge[]

  @@index([role])
  @@index([storeId])
  @@index([regionId])
}

// ==================== Web Push Notifications ====================

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  lastUsedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==================== Training ====================

model Training {
  id              String   @id @default(uuid())
  title           String
  description     String?
  category        String?
  type            String   @default("MANDATORY") // MANDATORY, OPTIONAL
  version         Int      @default(1)
  status          String   @default("ACTIVE") // ACTIVE, ARCHIVED
  durationMinutes Int?
  minPassRate     Int      @default(70) // Minimum pass percentage
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy   User                 @relation(fields: [createdById], references: [id])
  contents    TrainingContent[]
  assignments TrainingAssignment[]
  quiz        Quiz?
}

model TrainingContent {
  id         String   @id @default(uuid())
  trainingId String
  type       String   // TEXT, FILE, VIDEO, IMAGE
  title      String?
  content    String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  training Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  @@index([trainingId])
}

model TrainingAssignment {
  id          String    @id @default(uuid())
  trainingId  String
  userId      String
  assignedById String?
  status      String    @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED, OVERDUE
  dueDate     DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  training   Training @relation(fields: [trainingId], references: [id])
  user       User     @relation("AssignedUser", fields: [userId], references: [id])
  assignedBy User?    @relation("AssignedBy", fields: [assignedById], references: [id])

  @@unique([trainingId, userId])
  @@index([userId])
  @@index([trainingId])
  @@index([status])
}

// ==================== Quiz & Assessment ====================

model Quiz {
  id               String   @id @default(uuid())
  trainingId       String   @unique
  title            String
  passScore        Int      @default(70)
  maxAttempts      Int      @default(3)
  timeLimitMinutes Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  training  Training       @relation(fields: [trainingId], references: [id])
  questions QuizQuestion[]
  attempts  QuizAttempt[]
}

model QuizQuestion {
  id            String @id @default(uuid())
  quizId        String
  type          String // MULTIPLE_CHOICE, TRUE_FALSE, SHORT_ANSWER
  question      String
  options       String? // JSON array
  correctAnswer String
  points        Int    @default(1)
  sortOrder     Int    @default(0)

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@index([quizId])
}

model QuizAttempt {
  id          String    @id @default(uuid())
  quizId      String
  userId      String
  score       Float?
  passed      Boolean?
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  quiz    Quiz         @relation(fields: [quizId], references: [id])
  user    User         @relation(fields: [userId], references: [id])
  answers QuizAnswer[]

  @@index([userId])
  @@index([quizId])
}

model QuizAnswer {
  id         String  @id @default(uuid())
  attemptId  String
  questionId String
  answer     String?
  isCorrect  Boolean?

  attempt  QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question QuizQuestion @relation(fields: [questionId], references: [id])
}

// ==================== KPI & Performance ====================

model KpiDefinition {
  id          String   @id @default(uuid())
  name        String
  description String?
  unit        String?
  targetValue Float?
  frequency   String   @default("MONTHLY") // DAILY, WEEKLY, MONTHLY, QUARTERLY
  scope       String   @default("STORE") // STORE, EMPLOYEE, REGION
  isActive    Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User       @relation(fields: [createdById], references: [id])
  entries   KpiEntry[]
}

model KpiEntry {
  id              String   @id @default(uuid())
  kpiDefinitionId String
  value           Float
  period          String
  storeId         String?
  userId          String?
  enteredById     String
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  kpiDefinition KpiDefinition @relation(fields: [kpiDefinitionId], references: [id])
  store         Store?        @relation(fields: [storeId], references: [id])
  user          User?         @relation("KpiUser", fields: [userId], references: [id])
  enteredBy     User          @relation("KpiEnteredBy", fields: [enteredById], references: [id])

  @@index([kpiDefinitionId])
  @@index([storeId])
  @@index([period])
}

// ==================== Feedback ====================

model Feedback {
  id          String    @id @default(uuid())
  title       String
  description String
  type        String    // OPERATIONAL_ISSUE, SUGGESTION, INCIDENT, PRAISE, TRAINING_NEED
  status      String    @default("NEW") // NEW, IN_REVIEW, ACTION_PLANNED, IMPLEMENTED, CLOSED
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  storeId     String?
  submittedById String
  assignedToId  String?
  dueDate     DateTime?
  closedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  store       Store?            @relation(fields: [storeId], references: [id])
  submittedBy User              @relation("SubmittedBy", fields: [submittedById], references: [id])
  assignedTo  User?             @relation("AssignedTo", fields: [assignedToId], references: [id])
  comments    FeedbackComment[]
  logs        FeedbackLog[]

  @@index([storeId])
  @@index([status])
  @@index([type])
}

model FeedbackComment {
  id         String   @id @default(uuid())
  feedbackId String
  userId     String
  content    String
  createdAt  DateTime @default(now())

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])
}

model FeedbackLog {
  id         String   @id @default(uuid())
  feedbackId String
  action     String
  oldValue   String?
  newValue   String?
  userId     String
  createdAt  DateTime @default(now())

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])
}

// ==================== System ====================

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model ManagerNote {
  id         String   @id @default(uuid())
  employeeId String
  authorId   String
  content    String
  type       String   @default("GENERAL") // GENERAL, POSITIVE, CONSTRUCTIVE, FOCUSED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee User @relation("NoteEmployee", fields: [employeeId], references: [id])
  author   User @relation("NoteAuthor", fields: [authorId], references: [id])

  @@index([employeeId])
}

// ==================== Pulse Survey ====================

model PulseSurvey {
  id          String   @id @default(uuid())
  title       String
  description String?
  period      String   // e.g. "2026-03"
  isActive    Boolean  @default(true)
  isAnonymous Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  expiresAt   DateTime?

  // Multi-choice poll fields (optional — when null, legacy scored survey)
  question    String?
  options     String?  // JSON array of strings

  createdBy  User                  @relation(fields: [createdById], references: [id])
  responses  PulseSurveyResponse[]

  @@index([period])
  @@index([isActive])
}

model PulseSurveyResponse {
  id          String   @id @default(uuid())
  surveyId    String
  userId      String
  overallScore Int?    // 1-5 scale (legacy scored surveys)
  workloadScore Int?   // 1-5
  teamScore    Int?    // 1-5
  managerScore Int?    // 1-5
  growthScore  Int?    // 1-5
  selectedOption Int?  // 0-based index for multi-choice polls
  comment      String?
  createdAt    DateTime @default(now())

  survey PulseSurvey @relation(fields: [surveyId], references: [id])
  user   User        @relation(fields: [userId], references: [id])

  @@unique([surveyId, userId])
  @@index([surveyId])
}

// ==================== Community ====================

model CommunityPost {
  id        String   @id @default(uuid())
  title     String
  content   String
  category  String   // TIPS, QUESTION, ANNOUNCEMENT, SUCCESS_STORY
  isPinned  Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User               @relation(fields: [authorId], references: [id])
  comments CommunityComment[]

  @@index([category])
  @@index([createdAt])
}

model CommunityComment {
  id        String   @id @default(uuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  post   CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User          @relation(fields: [authorId], references: [id])

  @@index([postId])
}

// ==================== Sales Simulation ====================

model SimScenario {
  id              String   @id @default(uuid())
  category        String   // MUSTERI_KARSILAMA, URUN_ONERME, ITIRAZ, EK_SATIS, IADE_SIKAYET
  title           String
  description     String?
  difficulty      String   @default("MEDIUM") // EASY, MEDIUM, HARD
  xpReward        Int      @default(20)
  customerContext String   // Customer intro (name, mood, situation)
  steps           String   // JSON: [{ npc, choices: [{ text, scores:{empati,bilgi,caprazSatis,kapanis}, feedback, isBest? }] }]
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attempts SimAttempt[]

  @@index([category])
  @@index([isActive])
}

model SimAttempt {
  id               String   @id @default(uuid())
  scenarioId       String
  userId           String
  score            Int      // 0-100 overall
  empatiScore      Int      @default(0)
  bilgiScore       Int      @default(0)
  caprazSatisScore Int      @default(0)
  kapanisScore     Int      @default(0)
  xpEarned         Int      @default(0)
  badge            String?  // optional badge code: ALTIN_SATICI, MUSTERI_KAHRAMANI, EMPATI_USTASI
  choices          String   // JSON: array of selected choice indices per step
  durationSeconds  Int?
  completedAt      DateTime @default(now())

  scenario SimScenario @relation(fields: [scenarioId], references: [id])
  user     User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([scenarioId])
  @@index([completedAt])
}

// ==================== Shift Management ====================

model Shift {
  id           String    @id @default(uuid())
  userId       String
  storeId      String
  date         DateTime  // The day of the shift (00:00 local)
  startTime    String    // "09:00"
  endTime      String    // "18:00"
  type         String    @default("FULL")     // MORNING, EVENING, FULL, NIGHT
  status       String    @default("SCHEDULED") // SCHEDULED, CONFIRMED, MISSED, SWAPPED
  notes        String?
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user      User       @relation("ShiftEmployee", fields: [userId], references: [id])
  store     Store      @relation(fields: [storeId], references: [id])
  createdBy User       @relation("ShiftCreator", fields: [createdById], references: [id])
  swaps     ShiftSwap[]

  @@index([userId])
  @@index([storeId])
  @@index([date])
}

model ShiftSwap {
  id              String   @id @default(uuid())
  originalShiftId String
  fromUserId      String
  toUserId        String
  reason          String?
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED
  approvedById    String?
  createdAt       DateTime @default(now())
  resolvedAt      DateTime?

  originalShift Shift @relation(fields: [originalShiftId], references: [id], onDelete: Cascade)
  fromUser      User  @relation("ShiftSwapFrom", fields: [fromUserId], references: [id])
  toUser        User  @relation("ShiftSwapTo", fields: [toUserId], references: [id])

  @@index([originalShiftId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([status])
}

// ==================== Leave Management ====================

model LeaveBalance {
  id            String   @id @default(uuid())
  userId        String
  year          Int
  totalDays     Int      @default(14)
  usedDays      Int      @default(0)
  remainingDays Int      @default(14)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, year])
  @@index([userId])
}

model LeaveRequest {
  id              String    @id @default(uuid())
  userId          String
  type            String    // ANNUAL, SICK, UNPAID, MARRIAGE, BEREAVEMENT, OTHER
  startDate       DateTime
  endDate         DateTime
  days            Int       // total working days (excluding weekends)
  reason          String?
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED
  approverId      String?
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user     User  @relation("LeaveRequester", fields: [userId], references: [id])
  approver User? @relation("LeaveApprover", fields: [approverId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([startDate])
}

// ==================== Gamification (XP & Badges) ====================

model XpTransaction {
  id        String   @id @default(uuid())
  userId    String
  amount    Int      // positive only
  source    String   // QUIZ_PASS, TRAINING_COMPLETE, SIMULATION, KPI_GOAL, STREAK_BONUS, BADGE_AWARD, COMMUNITY_POST
  sourceId  String?  // related entity id (e.g. quizAttemptId, trainingId)
  reason    String   // human-readable label
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([source])
  @@index([createdAt])
}

model Badge {
  id          String   @id @default(uuid())
  code        String   @unique // ALTIN_SATICI, EMPATI_USTASI, etc.
  name        String
  description String
  icon        String   // material icon name
  color       String   // hex
  tier        String   @default("BRONZE") // BRONZE, SILVER, GOLD, PLATINUM
  category    String   @default("GENERAL") // TRAINING, QUIZ, SIMULATION, COMMUNITY, KPI, STREAK, GENERAL
  criteria    String?  // JSON describing how to earn (for display only)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  userBadges UserBadge[]
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())
  context   String?  // optional context (e.g. scenarioId, quizId)

  user  User  @relation(fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
}

// ==================== Store League (Seasons) ====================

model Season {
  id          String   @id @default(uuid())
  name        String   // "2026 Q1", "Bahar 2026"
  startDate   DateTime
  endDate     DateTime
  status      String   @default("UPCOMING") // UPCOMING, ACTIVE, COMPLETED
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scores LeagueScore[]

  @@index([status])
  @@index([startDate])
}

model LeagueScore {
  id              String   @id @default(uuid())
  seasonId        String
  storeId         String
  totalPoints     Float    @default(0)
  trainingPoints  Float    @default(0)
  kpiPoints       Float    @default(0)
  qualityPoints   Float    @default(0)
  quizPoints      Float    @default(0)
  rank            Int?
  lastCalculated  DateTime @default(now())

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  store  Store  @relation(fields: [storeId], references: [id])

  @@unique([seasonId, storeId])
  @@index([seasonId])
  @@index([storeId])
  @@index([totalPoints])
}

// ==================== App Notifications ====================
// In-app bildirim sistemi — kullanıcının çan ikonunda görünür
// Type: TRAINING_ASSIGNED, QUIZ_FAILED_RETRY, LEAVE_APPROVED, LEAVE_REJECTED,
//       LEAVE_REQUESTED (manager için), AI_RECOMMENDATION, GENERAL

model Notification {
  id        String   @id @default(uuid())
  userId    String   // Alıcı kullanıcı
  type      String   // Bildirim tipi (yukarıdaki enum gibi)
  title     String   // Kısa başlık
  message   String   // Detay metin
  link      String?  // Tıklayınca gidilecek sayfa (örn: /trainings/abc123)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  readAt    DateTime?

  user User @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}
